# =============================================================================
# Telegram уведомления (нужны для scanner_runner.py)
# =============================================================================
# Как получить TELEGRAM_BOT_TOKEN:
#   1. Открой Telegram и найди бота @BotFather
#   2. Напиши /newbot
#   3. Выбери имя и username для бота
#   4. BotFather пришлёт токен — вставь его сюда
#
# Как получить TELEGRAM_CHAT_ID:
#   1. Напиши что-нибудь своему новому боту в Telegram
#   2. Открой в браузере:
#      https://api.telegram.org/bot<ВАШ_ТОКЕН>/getUpdates
#   3. Найди поле "id" внутри "chat" — это и есть TELEGRAM_CHAT_ID
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=